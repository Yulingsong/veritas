{
  "name": "veritas",
  "version": "1.0.0",
  "description": "AI-powered frontend testing with real browser and API data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veritas": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "test": "node dist/cli/index.js",
    "test:unit": "vitest run",
    "test:integration": "vitest run --integration",
    "test:coverage": "vitest run --coverage",
    "generate": "tsx src/cli/index.ts generate",
    "record": "tsx src/cli/index.ts record",
    "mock": "tsx src/cli/index.ts mock",
    "auto": "tsx src/cli/index.ts auto",
    "analyze": "tsx src/cli/index.ts analyze",
    "report": "tsx src/cli/index.ts report",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "test",
    "automation",
    "frontend",
    "react",
    "vue",
    "playwright",
    "vitest",
    "jest",
    "testing",
    "mock",
    "coverage"
  ],
  "author": "Yulingsong",
  "license": "MIT",
  "homepage": "https://github.com/Yulingsong/veritas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yulingsong/veritas.git"
  },
  "bugs": {
    "url": "https://github.com/Yulingsong/veritas/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/veritas"
  }
}
