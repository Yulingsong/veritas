{
  "name": "veritas",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered frontend testing with real browser and API data",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "veritas": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc && tsc --emitDeclarationOnly",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "release": "standard-version",
    "publish": "npm publish --access public"
  },
  "keywords": [
    "ai",
    "test",
    "automation",
    "frontend",
    "react",
    "vue",
    "playwright",
    "vitest",
    "jest",
    "testing",
    "mock",
    "coverage"
  ],
  "author": "Yulingsong",
  "license": "MIT",
  "homepage": "https://github.com/Yulingsong/veritas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yulingsong/veritas.git"
  },
  "bugs": {
    "url": "https://github.com/Yulingsong/veritas/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "standard-version": "^9.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/veritas"
  }
}
