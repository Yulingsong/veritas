{
  "name": "veritas",
  "version": "1.0.0",
  "description": "AI-powered frontend testing with real browser and API data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "veritas": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "test": "node dist/cli/index.js",
    "generate": "tsx src/cli/index.ts generate",
    "record": "tsx src/cli/index.ts record",
    "auto": "tsx src/cli/index.ts auto",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": ["ai", "test", "automation", "frontend", "react", "playwright", "veritas"],
  "author": "Yulingsong",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yulingsong/veritas.git"
  }
}
